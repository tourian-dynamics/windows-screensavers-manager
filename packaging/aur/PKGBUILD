# Maintainer: Jeryd <jerydleuck@gmail.com>
pkgname=ridle
pkgver=TEMPLATE_VERSION
pkgrel=1
pkgdesc="TUI screensaver manager"
arch=('x86_64')
url="https://github.com/local76/rIdle"
license=('MIT')
depends=('libc')
makedepends=('rust' 'cargo')
source=("${pkgname}-${pkgver}.tar.gz::https://github.com/local76/rIdle/archive/v${pkgver}.tar.gz")
sha256sums=('SKIP')

build() {
  cd "${pkgname}-${pkgver}"
  cargo build --release
}

package() {
  cd "${pkgname}-${pkgver}"
  install -Dm755 "target/release/ridle" "${pkgdir}/usr/bin/ridle"
}