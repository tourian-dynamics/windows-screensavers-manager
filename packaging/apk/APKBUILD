# Maintainer: UberMetroid <ubermetroid@users.noreply.github.com>
pkgname=ridle
pkgver=TEMPLATE_VERSION
pkgrel=1
pkgdesc="A project template for creating unified local terminal utilities in Rust"
url="https://github.com/local76/rIdle"
arch="x86_64"
license="MIT"
depends=""
makedepends="cargo"
source="$pkgname-$pkgver.tar.gz"

build() {
	cargo build --release --locked
}

package() {
	install -Dm755 target/release/ridle "$pkgdir"/usr/bin/ridle
}
